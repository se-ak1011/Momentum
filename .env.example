# Supabase — copy from Project Settings > API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# OpenAI — keep this SECRET, consider proxying through your backend in production
EXPO_PUBLIC_OPENAI_API_KEY=sk-replace-me

# Optional extras
EXPO_PUBLIC_API_BASE_URL=https://api.example.com
EXPO_PUBLIC_ANALYTICS_KEY=replace-me

# EAS / bundle identifiers (set once per project)
EXPO_PUBLIC_EAS_PROJECT_ID=replace-with-eas-project-id
EXPO_PUBLIC_IOS_BUNDLE_ID=com.example.momentum
EXPO_PUBLIC_ANDROID_PACKAGE=com.example.momentum
